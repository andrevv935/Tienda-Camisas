# Supabase Postgres connection string.
# Use the URI from Supabase: Project Settings -> Database -> Connection string.
# Recommended: Session pooler URI.
SUPABASE_DB_URL=postgresql://<user>:<password>@<host>:6543/postgres?sslmode=require

# Backward-compatible alias used by existing scripts.
DATABASE_URL=postgresql://<user>:<password>@<host>:6543/postgres?sslmode=require